#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Ответственный = Пользователи.ТекущийПользователь();
	
КонецПроцедуры
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записывать = Истина;

	Движения.ВКМ_ВзаиморасчетыССотрудниками.Очистить();
	Движения.ВКМ_ВзаиморасчетыССотрудниками.Записать(); 
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ВКМ_ВзаиморасчетыССотрудниками");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = Выплаты;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Сотрудник", "Сотрудник");
	Блокировка.Заблокировать();
	
	СписокСотрудников = Выплаты.ВыгрузитьКолонку("Сотрудник");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВКМ_ВзаиморасчетыССотрудникамиОстатки.Сотрудник КАК Сотрудник,
		|	ЕСТЬNULL(ВКМ_ВзаиморасчетыССотрудникамиОстатки.СуммаОстаток, 0) КАК Остаток
		|ИЗ
		|	РегистрНакопления.ВКМ_ВзаиморасчетыССотрудниками.Остатки(&Бесконечность, Сотрудник В (&СписокСотрудников)) КАК
		|		ВКМ_ВзаиморасчетыССотрудникамиОстатки";
	
	КонецВремен = Дата(3999, 12, 31, 23, 59, 59);
	Запрос.УстановитьПараметр("Бесконечность", Новый Граница(КонецВремен, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СписокСотрудников", СписокСотрудников);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	РезультатЗапроса.Индексы.Добавить("Сотрудник"); 
	
	Для Каждого СтрокаВыплаты Из Выплаты Цикл
		
		СтрокаОстатка = РезультатЗапроса.Найти(СтрокаВыплаты.Сотрудник, "Сотрудник");
		
		ТекущийДолг = 0;
		Если СтрокаОстатка <> Неопределено Тогда
			ТекущийДолг = СтрокаОстатка.Остаток;
		КонецЕсли;
		
		Если СтрокаВыплаты.Сумма > ТекущийДолг Тогда
			
			ТекстОшибки = СтрШаблон(НСтр("ru = 'По сотруднику %1 превышена сумма выплаты! Доступно к выплате: %2, введено: %3'"), 
				СтрокаВыплаты.Сотрудник, ТекущийДолг, СтрокаВыплаты.Сумма);
			
			ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки,
				ЭтотОбъект,
				"Выплаты[" + Выплаты.Индекс(СтрокаВыплаты) + "].Сумма",
				"Объект",
				Отказ);
		КонецЕсли;
		
	КонецЦикла;

	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	Для Каждого ТекСтрокаВыплаты Из Выплаты Цикл
		Движение = Движения.ВКМ_ВзаиморасчетыССотрудниками.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Сотрудник = ТекСтрокаВыплаты.Сотрудник;
		Движение.Сумма = ТекСтрокаВыплаты.Сумма;
	КонецЦикла;
	 
КонецПроцедуры

#КонецОбласти

#КонецЕсли