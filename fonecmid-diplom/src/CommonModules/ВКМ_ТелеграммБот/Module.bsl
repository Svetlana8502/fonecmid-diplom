#Область ПрограммныйИнтерфейс

// Программный интерфейс интеграции с Telegram Bot API
//
// Назначение:
// Данная область содержит экспортируемую процедуру для автоматической отправки сообщений
// из справочника 1С в Telegram. Процедура выполняет следующие действия:
// 1. Получает токен бота из константы конфигурации.
// 2. Выбирает неотправленные сообщения из справочника ВКМ_ТелеграммБотУведомление.
// 3. Формирует JSON-запросы для Telegram Bot API (метод sendMessage).
// 4. Отправляет сообщения в указанную TelegramГруппу (ID: 951644345).
// 5. Удаляет успешно отправленные записи из справочника.
// 6. Логирует ошибки при неудачных попытках отправки.
//
// Используемые константы:
// - ВКМ_ТокенУправленияТГБотом — токен Telegram_бота от BotFather.
// - ВКМ_ИдентификаторГруппыДляОповещения — ID чата/группы в Telegram
//   (в текущей реализации жёстко задано значение "951644345").
//
// Зависимости:
// - Справочник ВКМ_ТелеграммБотУведомление с реквизитом ВКМ_ТекстСоббщения
//   (хранит тексты сообщений для отправки).
// - Доступ к api.telegram.org (порт 443, HTTPS).
//
// Особенности реализации:
// - Используется HTTPS-соединение с SSL-шифрованием.
// - JSON-сериализация выполняется через объект ЗаписьJSON.
// - Обработка ошибок включает логирование в журнал регистрации 1С.
// - Для каждого сообщения выполняется отдельный HTTP-запрос к Telegram API.
//
// Требования к настройке:
// 1. В константе ВКМ_ТокенУправленияТГБотом должен быть указан корректный токен бота.
// 2. Бот с указанным токеном должен иметь права на отправку сообщений в группу с ID 951644345.
// 3. У учётной записи 1С должны быть права на чтение справочника ВКМ_ТелеграммБотУведомление
//    и удаление записей из него.

// ВКМ телеграмм бот.
Процедура ВКМ_ТелеграммБот() Экспорт
    
    // Автоматическая отправка сообщений из справочника ВКМ_ТелеграммБотУведомление в Telegram-Группу.
    // 
    //  Параметры: 
    //   отсутствуют.
    // Возвращаемое значение: 
    //   отсутствует.
    //
    // Исключения:
    //  - Вызывает исключение, если токен бота не настроен в константах.
    //  - Логирует и перебрасывает любые возникающие исключения.
    //
    // Пример вызова:
    // ВКМ_ТелеграммБот();
	//
    Попытка
        ТокенБот = Константы.ВКМ_ТокенУправленияТГБотом.Получить();
        Если ПустаяСтрока(ТокенБот) Тогда
            ВызватьИсключение "Токен_Бот не настроен в константах";
        КонецЕсли;

        HTTPСоединение = Новый HTTPСоединение("api.telegram.org", 443, , , , Новый ЗащищенноеСоединениеOpenSSL());
        Путь = "/bot" + ТокенБот + "/sendMessage";

        Запрос = Новый Запрос;
        Запрос.Текст = "ВЫБРАТЬ
            | ВКМ_ТелеграммБотУведомление.Ссылка,
            | ВКМ_ТелеграммБотУведомление.ВКМ_ТекстСоббщения КАК ТекстСообщения
            |ИЗ
            | Справочник.ВКМ_ТелеграммБотУведомление КАК ВКМ_ТелеграммБотУведомление";

        РезультатЗапроса = Запрос.Выполнить().Выбрать();

        Пока РезультатЗапроса.Следующий() Цикл
            // Создаём JSON-сериализатор
            ЗаписьJSON = Новый ЗаписьJSON;
            ЗаписьJSON.УстановитьСтроку();
            
            // Подготавливаем данные для отправки
            ДанныеСообщения = Новый Структура;
           
            // Используем жёстко заданное значение ID чата
            ДанныеСообщения.Вставить("chat_id", "951644345");
            ДанныеСообщения.Вставить("text", РезультатЗапроса.ТекстСообщения);

            // Сериализуем структуру в JSON
            ЗаписатьJSON(ЗаписьJSON, ДанныеСообщения);
            СтрокаJSON = ЗаписьJSON.Закрыть();

            // Настраиваем HTTP-запрос
            HTTPЗапрос = Новый HTTPЗапрос(Путь);
            HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
            HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаJSON);

            // Отправляем запрос
            //@skip-check bsl-legacy-check-dynamic-feature-access
            HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);

            Если HTTPОтвет.КодСостояния = 200 Тогда
                ДокОбъект = РезультатЗапроса.Ссылка.ПолучитьОбъект();
                ДокОбъект.Удалить();
            Иначе
                Ошибка = "Ошибка отправки сообщения. HTTP код: " + HTTPОтвет.КодСостояния;
                ЗаписьЖурналаРегистрации("ВКМ_ТелеграммБот", УровеньЖурналаРегистрации.Ошибка, "Ошибка", , Ошибка);
            КонецЕсли;
        КонецЦикла;
    Исключение
        Ошибка = ИнформацияОбОшибке();
        ЗаписьЖурналаРегистрации("ВКМ_ТелеграммБот", УровеньЖурналаРегистрации.Ошибка, "Исключение", , Ошибка);
        ВызватьИсключение Ошибка;
    КонецПопытки;
КонецПроцедуры

#КонецОбласти

